<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shamayev — Онбординг</title>
<style>
:root{
  --teal:#1A6B5A;--teal-d:#134D41;--teal-l:#2A8570;--teal-xl:#E8F4F1;
  --red:#D93B2B;--red-l:#F7EEEC;
  --white:#fff;--off:#F6F8F7;--gray:#6B7B76;--gray-l:#E2ECEA;
  --dark:#111E1A;--gold:#C9A96E;--gold-l:#FBF5EC;--gold-d:#7A5B1A;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--off);color:var(--dark)}
.nav{background:#fff;border-bottom:1px solid var(--gray-l);padding:0 20px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200}
.brand{font-size:19px;font-weight:700;color:var(--teal);letter-spacing:-.3px}
.lvl-pill{background:var(--teal);color:#fff;border-radius:20px;padding:5px 14px;font-size:12px;font-weight:500;display:flex;align-items:center;gap:5px}
.av{width:30px;height:30px;border-radius:50%;background:var(--teal);color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600}
.tabs{background:#fff;border-bottom:1px solid var(--gray-l);display:flex;overflow-x:auto;padding:0 12px}
.tab{padding:10px 13px;font-size:11px;font-weight:500;white-space:nowrap;cursor:pointer;border-bottom:2.5px solid transparent;color:var(--gray);flex-shrink:0;transition:all .15s}
.tab.active{border-bottom-color:var(--teal);color:var(--teal);font-weight:600}
.page{max-width:960px;margin:0 auto;padding:18px 16px}
.two{display:grid;grid-template-columns:1fr 310px;gap:14px}
.hero{border-radius:16px;padding:22px 22px 18px;margin-bottom:14px;position:relative;overflow:hidden}
.hero::after{content:"";position:absolute;right:-40px;top:-40px;width:200px;height:200px;border:35px solid rgba(255,255,255,.06);border-radius:50%}
.h-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:14px}
.h-lbl{font-size:11px;color:rgba(255,255,255,.6);margin-bottom:4px}
.h-ttl{font-size:19px;font-weight:600;color:#fff}
.h-sub{font-size:12px;color:rgba(255,255,255,.65);margin-top:3px}
.hbdg{background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.3);border-radius:12px;padding:10px 14px;text-align:center;flex-shrink:0;min-width:88px}
.hbdg-i{font-size:22px;margin-bottom:3px}
.hbdg-n{font-size:11px;color:rgba(255,255,255,.85);font-weight:600}
.hbdg-s{font-size:10px;color:rgba(255,255,255,.5);margin-top:1px}
.hstats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:14px}
.hst{background:rgba(255,255,255,.15);border-radius:10px;padding:10px 8px;text-align:center}
.hst-n{font-size:20px;font-weight:700;color:#fff}
.hst-l{font-size:10px;color:rgba(255,255,255,.6);margin-top:2px}
.prow{display:flex;justify-content:space-between;margin-bottom:5px;align-items:center}
.pc{font-size:12px;color:rgba(255,255,255,.7)}
.pp{font-size:20px;font-weight:700;color:#fff}
.pn{font-size:12px;color:rgba(255,255,255,.5)}
.pw{background:rgba(255,255,255,.2);border-radius:6px;height:9px;overflow:hidden;margin-bottom:5px}
.pb{height:100%;border-radius:6px;background:var(--red);transition:width .5s}
.ph{font-size:11px;color:rgba(255,255,255,.5)}
.lpath{display:flex;border:1px solid var(--gray-l);border-radius:12px;overflow:hidden;margin-bottom:14px}
.lp{flex:1;text-align:center;padding:9px 4px;border-right:1px solid var(--gray-l);cursor:pointer}
.lp:last-child{border-right:none}
.lp.dn{background:var(--teal-xl)}.lp.ac{background:var(--teal)}.lp.ft{background:#fff;opacity:.5}
.lpn{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;margin:0 auto 3px}
.dn .lpn{background:var(--teal);color:#fff}.ac .lpn{background:var(--red);color:#fff}.ft .lpn{background:var(--gray-l);color:var(--gray)}
.lpl{font-size:9px;font-weight:500}
.dn .lpl{color:var(--teal)}.ac .lpl{color:rgba(255,255,255,.85)}.ft .lpl{color:var(--gray)}
.sec{font-size:10px;font-weight:600;color:var(--gray);letter-spacing:.07em;text-transform:uppercase;margin-bottom:9px;display:flex;align-items:center;gap:8px}
.sec::after{content:"";flex:1;height:1px;background:var(--gray-l)}
.card{background:#fff;border:1px solid var(--gray-l);border-radius:14px;padding:16px;margin-bottom:10px}
.qr{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--gray-l)}
.qr:last-child{border-bottom:none;padding-bottom:0}.qr:first-child{padding-top:0}
.qch{width:22px;height:22px;border-radius:6px;border:1.5px solid var(--gray-l);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;font-size:11px;margin-top:2px;transition:all .15s;background:#fff}
.qch.done{background:var(--teal);border-color:var(--teal);color:#fff}
.qi{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.qb{flex:1}.qt{font-size:13px;font-weight:500;color:var(--dark);line-height:1.3}
.qs{font-size:11px;color:var(--gray);margin-top:2px}
.qm{display:flex;align-items:center;gap:5px;margin-top:5px;flex-wrap:wrap}
.tag{font-size:10px;font-weight:500;padding:2px 7px;border-radius:10px}
.tg{background:var(--teal-xl);color:var(--teal)}.tr{background:var(--red-l);color:var(--red)}.to{background:var(--gold-l);color:var(--gold-d)}.tgr{background:var(--gray-l);color:var(--gray)}
.bdg{border:1.5px solid var(--gray-l);border-radius:12px;padding:11px 8px;text-align:center;position:relative}
.bdg.earned{border-color:var(--gold);background:var(--gold-l)}
.bdg.locked{opacity:.4}
.bdg-i{font-size:22px;display:block;margin-bottom:4px}
.bdg-n{font-size:11px;font-weight:600;color:var(--dark);line-height:1.3}
.bdg-d{font-size:10px;color:var(--gray);margin-top:2px}
.bdg-ck{position:absolute;top:6px;right:6px;width:15px;height:15px;background:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;color:#fff}
.buav{width:44px;height:44px;border-radius:50%;background:var(--teal);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;flex-shrink:0}
.buq{background:var(--teal-xl);border-left:3px solid var(--teal);border-radius:0 8px 8px 0;padding:10px 12px;font-size:12px;color:var(--teal-d);line-height:1.5;margin-top:8px;font-style:italic}
.bpr{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--gray-l)}
.bpr:last-child{border-bottom:none}
.bpr-bar{background:var(--gray-l);border-radius:4px;height:5px;overflow:hidden;margin-top:3px}
.bpr-fill{height:100%;border-radius:4px;background:var(--teal);transition:width .4s}
.vcard{border:1.5px solid var(--gray-l);border-radius:10px;padding:10px 12px;cursor:pointer;transition:all .15s;margin-bottom:7px;display:flex;align-items:center;gap:10px}
.vcard:hover{border-color:var(--teal-l)}.vcard.learned{border-color:var(--teal);background:var(--teal-xl)}
.vc-s{margin-left:auto;font-size:10px;font-weight:600;padding:2px 7px;border-radius:6px;flex-shrink:0}
.vc-s.done{background:var(--teal);color:#fff}.vc-s.todo{background:var(--gray-l);color:var(--gray)}
.mqo{border:1.5px solid var(--gray-l);border-radius:8px;padding:9px 12px;cursor:pointer;font-size:12px;color:var(--dark);margin-bottom:5px;background:#fff;transition:all .15s;line-height:1.4}
.mqo:hover{border-color:var(--teal)}.mqo.ok{border-color:var(--teal);background:var(--teal-xl);color:var(--teal-d)}.mqo.no{border-color:var(--red);background:var(--red-l);color:#7A1A0D}
.mqfb{font-size:11px;margin-top:6px;padding:8px 10px;border-radius:7px;display:none;line-height:1.5}
.vfull{background:var(--dark);border-radius:14px;padding:22px;text-align:center;margin-bottom:10px;width:100%}
.vplay{width:52px;height:52px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;cursor:pointer}
.ins{background:var(--teal-d);border-radius:14px;padding:20px;margin-top:12px}
.ins-opts{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.io{background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.2);border-radius:10px;padding:10px 6px;text-align:center;cursor:pointer;transition:all .15s}
.io:hover{background:rgba(255,255,255,.22)}.io.p{background:var(--teal);border-color:var(--teal-l)}
.io-i{font-size:22px;display:block;margin-bottom:3px}
.io-l{font-size:10px;color:rgba(255,255,255,.8);font-weight:500}
.ins-ta{width:100%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#fff;resize:none;height:68px;outline:none;font-family:inherit;margin-bottom:10px}
.ins-ta::placeholder{color:rgba(255,255,255,.4)}
.ins-btn{background:#fff;color:var(--teal);border:none;border-radius:20px;padding:9px 22px;font-size:12px;font-weight:600;cursor:pointer;width:100%}
.rc{background:#fff;border:1px solid var(--gray-l);border-radius:12px;padding:14px;margin-bottom:7px;cursor:pointer;position:relative;transition:all .2s}
.rc.rv{border-color:var(--teal);background:var(--teal-xl)}
.rc-num{width:28px;height:28px;border-radius:50%;background:var(--teal);color:#fff;font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s}
.rc.rv .rc-num{background:var(--red)}
.rc-tag{position:absolute;top:10px;right:12px;font-size:9px;background:var(--gray-l);color:var(--gray);padding:2px 6px;border-radius:4px;transition:all .2s}
.rc.rv .rc-tag{background:var(--teal);color:#fff}
.schips{display:grid;grid-template-columns:repeat(6,1fr);gap:5px;margin-bottom:14px}
.scp{background:#fff;border:1px solid var(--gray-l);border-radius:10px;padding:10px 4px;text-align:center;transition:all .2s}
.scp.done{border-color:var(--teal);background:var(--teal-xl)}
.scp-i{font-size:14px;margin-bottom:3px}
.scp-l{font-size:9px;color:var(--gray)}
.scp.done .scp-l{color:var(--teal);font-weight:600}
.trt{background:var(--off);border:1.5px solid var(--gray-l);border-radius:10px;padding:12px 14px;margin-bottom:8px}
.trq{font-size:12px;font-weight:600;color:var(--dark);margin-bottom:9px;line-height:1.4}
.tro{border:1.5px solid var(--gray-l);border-radius:8px;padding:9px 12px;cursor:pointer;font-size:11px;font-family:monospace;color:var(--dark);margin-bottom:5px;background:#fff;transition:all .15s;line-height:1.4}
.tro:hover{border-color:var(--teal)}.tro.cor{border-color:var(--teal);background:var(--teal-xl);color:var(--teal-d)}.tro.wr{border-color:var(--red);background:var(--red-l);color:#7A1A0D}
.trfb{margin-top:7px;font-size:11px;padding:8px 10px;border-radius:7px;display:none;line-height:1.5}
.bqi{margin-bottom:13px;padding-bottom:13px;border-bottom:1px solid var(--gray-l);counter-increment:bn}
.bqi:last-child{border-bottom:none;margin-bottom:0}
.bqq{font-size:12px;font-weight:600;color:var(--dark);margin-bottom:8px;line-height:1.4}
.bqq::before{content:counter(bn)". "}
.bqo{border:1.5px solid var(--gray-l);border-radius:7px;padding:8px 12px;cursor:pointer;font-size:12px;color:var(--dark);margin-bottom:5px;background:#fff;transition:all .15s}
.bqo:hover{border-color:var(--teal)}.bqo.ok{border-color:var(--teal);background:var(--teal-xl);color:var(--teal-d)}.bqo.no{border-color:var(--red);background:var(--red-l);color:#7A1A0D}
.bqfb{font-size:11px;margin-top:5px;padding:7px 10px;border-radius:6px;display:none;line-height:1.5}
.score-box{background:var(--teal);border-radius:12px;padding:14px;text-align:center;margin-top:10px;display:none}
.dc{border:1px solid var(--gray-l);border-radius:10px;padding:9px 12px;margin-bottom:6px;display:flex;gap:10px;align-items:flex-start}
.da{font-size:11px;font-weight:700;color:var(--teal);background:var(--teal-xl);padding:4px 8px;border-radius:6px;flex-shrink:0;min-width:54px;text-align:center}
.df{font-size:12px;font-weight:500;color:var(--dark);line-height:1.3}
.de{font-size:10px;color:var(--gray);margin-top:2px;font-style:italic}
.urow{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--gray-l);font-size:12px;color:var(--dark)}
.urow:last-child{border-bottom:none}
.creative{background:var(--dark);border-radius:14px;padding:20px;margin-top:8px}
.btn{border:none;border-radius:25px;padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s}
.btn-t{background:var(--teal);color:#fff;width:100%;margin-top:10px}
.btn-r{background:var(--red);color:#fff;width:100%;margin-top:10px}
.carousel-wrap{position:relative;overflow:hidden}
.carousel-track{display:flex;transition:transform .35s ease}
.carousel-slide{min-width:100%;padding:0 2px}
.carousel-nav{display:flex;align-items:center;justify-content:space-between;margin-top:10px}
.cnavbtn{background:none;border:1px solid var(--gray-l);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:500;cursor:pointer;color:var(--gray);transition:all .15s}
.cnavbtn:hover{border-color:var(--teal);color:var(--teal)}
.cnavbtn:disabled{opacity:.3;cursor:default}
.cdots{display:flex;gap:5px}
.cdot{width:7px;height:7px;border-radius:50%;background:var(--gray-l);transition:all .2s;cursor:pointer}
.cdot.active{background:var(--teal);width:20px;border-radius:4px}
.cprog{font-size:11px;color:var(--gray)}
.cq-label{font-size:10px;font-weight:600;color:var(--teal);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.cq-q{font-size:13px;font-weight:500;color:var(--dark);line-height:1.45;margin-bottom:10px}
.video-16-9{width:100%;aspect-ratio:16/9;background:var(--dark);border-radius:14px;display:flex;flex-direction:column;align-items:center;justify-content:center;margin-bottom:14px}
.rating-wrap{display:flex;gap:8px;justify-content:center;margin:10px 0}
.star{font-size:32px;cursor:pointer;transition:transform .15s;filter:grayscale(1);opacity:.4}
.star:hover,.star.active{filter:none;opacity:1;transform:scale(1.15)}
.cel-wrap{background:rgba(0,0,0,.45);border-radius:16px;padding:28px 16px;text-align:center;display:none;margin-top:12px}
.cel-box{background:#fff;border-radius:20px;padding:28px 22px;max-width:460px;margin:0 auto}
@keyframes pop{0%{transform:scale(.5);opacity:0}70%{transform:scale(1.05)}100%{transform:scale(1);opacity:1}}
@keyframes fl{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.pa{animation:pop .5s ease forwards}
.fa{animation:fl 2s ease-in-out infinite}
@media(max-width:680px){
  .two{grid-template-columns:1fr}
  .hstats{grid-template-columns:repeat(2,1fr)}
  .ins-opts{grid-template-columns:repeat(2,1fr)}
  .schips{grid-template-columns:repeat(3,1fr)}
}
/* ── LEVEL-UP POPUP ── */
#lvlPopup{display:none;position:fixed;inset:0;z-index:9999;background:rgba(10,30,20,.85);align-items:center;justify-content:center}
#lvlPopup.show{display:flex;animation:lvlFadeIn .2s ease}
@keyframes lvlFadeIn{from{opacity:0}to{opacity:1}}
.lvl-box{background:#fff;border-radius:20px;padding:32px 28px 24px;max-width:320px;width:90%;text-align:center;position:relative;animation:lvlPop .35s cubic-bezier(.34,1.56,.64,1)}
@keyframes lvlPop{from{transform:scale(.65);opacity:0}to{transform:scale(1);opacity:1}}
.lvl-emoji{font-size:52px;display:block;margin-bottom:10px;animation:lvlBounce 1.2s ease infinite alternate}
@keyframes lvlBounce{from{transform:translateY(0) rotate(-5deg)}to{transform:translateY(-10px) rotate(5deg)}}
.lvl-title{font-size:21px;font-weight:700;color:var(--teal-d);margin-bottom:5px}
.lvl-badge{display:inline-block;background:linear-gradient(135deg,var(--teal),var(--teal-l));color:#fff;border-radius:20px;padding:4px 18px;font-size:14px;font-weight:600;margin-bottom:12px}
.lvl-msg{font-size:13px;color:var(--gray);line-height:1.65;margin-bottom:20px}
.lvl-btn{background:var(--red);color:#fff;border:none;border-radius:12px;padding:11px 28px;font-size:14px;font-weight:600;cursor:pointer;width:100%;transition:opacity .15s}
.lvl-btn:hover{opacity:.88}
</style>
</head>
